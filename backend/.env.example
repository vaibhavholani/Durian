GEMINI_API_KEY=your_gemini_api_key_here

# Optional: switch model (gemini-2.0-flash, gemini-1.5-pro, etc.)
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: switch Claude model (default: claude-sonnet-4-6-20250514)
CLAUDE_MODEL=claude-sonnet-4-5-20241022

# Default AI provider: claude or gemini
AI_PROVIDER=claude

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage path for job data and feedback
DATA_DIR=./data

# Langfuse observability
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
MACHINE_NAME="your machine name"
